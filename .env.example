# ShellTeam (self-hosted, native edition) — environment configuration
# Copy to .env and fill in. `install.sh` generates a .env from this template
# and auto-fills the secrets marked AUTO-GENERATED. Never commit .env.

# ── Core ────────────────────────────────────────────────────────────────────
# Runtime backend is fixed to native in the public edition.
RUNTIME=native

# Opt-in modules (comma-separated). EMPTY = pure core: cockpit agents get ZERO
# ShellTeam injection — no skills, no MCP servers, no appended system prompt;
# behavior is bit-identical to running the CLI by hand (contract-tested).
# Available modules:
#   persona  — ShellTeam's assistant layer: system prompt + skills + hooks +
#              docs MCP (context7, deepwiki)
#   browser  — shared Steel browser MCP (part of ./install.sh --full)
#   composio — app connections over MCP (also set COMPOSIO_API_KEY)
#   linear   — Linear MCP (also set LINEAR_API_KEY)
#   dreaming — nightly knowledge consolidation on your own subscription: a
#              03:30 systemd timer distils the day's agent sessions into
#              ~/.shellteam/knowledge/ (per-folder tree), agents spawn with
#              their folder's knowledge, and the dashboard gains a Knowledge
#              tab (docs/decisions/20260708-dreaming-v1.md)
# Example full experience: MODULES=persona,browser,dreaming
MODULES=

# Automatic updates (off | daily | weekly). Off by default: you stay in charge
# of when your box changes. When on, a daily 03:10 systemd timer fast-forwards
# the checkout to the latest release tag and re-runs install.sh (services
# restart), rolling back if the update comes up unhealthy. It never touches a
# dirty working tree or a diverged checkout. Toggleable from dashboard Settings.
AUTO_UPDATE=off

# Domain the cockpit is served on. Use a real domain in production (Caddy issues
# TLS for it and "<anything>.<APP_DOMAIN>" subdomains). For laptop use, leave it
# as localhost and reach the app at http://127.0.0.1:8000.
APP_DOMAIN=localhost

# Public IP of the VPS (only needed when serving on a public interface so the
# control plane treats direct-IP hits as the dashboard host). Leave empty for
# localhost use.
VPS_IP=

# ── Single-owner identity ─────────────────────────────────────────────────────
# The whole box belongs to one owner. These name that owner.
OWNER_ID=owner
OWNER_USERNAME=owner
OWNER_EMAIL=owner@localhost

# Auth boundary. When the box is bound to anything other than 127.0.0.1, set a
# strong OWNER_TOKEN — every request must then present it (Bearer header, ?token=
# query param, or shellteam_token cookie). Leave EMPTY only for localhost-trust.
# install.sh auto-generates one when you choose a public bind.
OWNER_TOKEN=

# ── Service ports ─────────────────────────────────────────────────────────────
# All three ports are configurable here. If a default is already taken on your
# box, change it and re-run ./install.sh (idempotent — it re-renders the units +
# nginx config and restarts). See INSTALL.md "Changing ports".
#
# Control plane (FastAPI). The dashboard + API live here; Caddy reverse-proxies to
# it. If you change this, update the reverse_proxy targets in your Caddyfile too.
API_PORT=8000
# The cockpit (ai-chat). Also the liveness signal for "is the computer up?".
AI_CHAT_PORT=3456
# The cloud-computer file server (nginx, serves $HOME). The subdomain proxy
# forwards bare-username requests here. Default 80; pick any free port if :80 is
# taken (e.g. 8081). Values >= 1024 need no privileged bind (install.sh then
# skips the nginx setcap step).
FILE_PORT=80
# Where in-box CLIs reach the control plane's /internal/ai proxy (OpenCode's
# Fireworks provider, etc.). Defaults to http://127.0.0.1:8000 — the built-in
# API_PORT. If you changed API_PORT above, set this to match (e.g. if you run OSS
# alongside another stack on 8000 and moved the API to 8001, set it to
# http://127.0.0.1:8001), otherwise OpenCode's proxied calls hit the wrong port.
AI_PROXY_BASE=http://127.0.0.1:8000

# ── Secrets (host-side) ───────────────────────────────────────────────────────
# HMAC secret shared between the control plane and the in-box tools/CLIs.
# AUTO-GENERATED by install.sh on first run — keep it stable across restarts.
SHELLTEAM_AI_TOKEN=

# ── LLM provider keys ─────────────────────────────────────────────────────────
# All optional — the preferred way to run the coding agents is a subscription
# login from the dashboard (Login with Claude / OpenAI). API keys set here are
# the fallback the CLIs pick up from the environment when there is no login.
# NOTE: no inline comments on assignment lines — systemd's EnvironmentFile=
# does not strip them, so `KEY=  # note` becomes a garbage value.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# FIREWORKS_API_KEY enables the OpenCode agent (server-side proxy — the key
# never leaves this box). Get one at https://fireworks.ai.
FIREWORKS_API_KEY=
# ELEVENLABS_API_KEY enables voice messages (speech-to-text) in the cockpit + feedback.
ELEVENLABS_API_KEY=
# Managed alternative (ShellTeam Cloud boxes): a metered relay we operate serves
# speech-to-text without any provider key on this box. Your own key above always
# takes precedence. Leave both empty on self-hosted installs.
SHELLTEAM_RELAY_URL=
SHELLTEAM_RELAY_TOKEN=

# ── Apps & integrations (optional) ────────────────────────────────────────────
# Composio is the opt-in "easy button" for 500+ app connections over MCP. The
# default is bring-your-own-MCP (add servers to ~/.claude.json). Leave empty to
# keep Composio off.
COMPOSIO_API_KEY=

# Linear: set a personal API key to let cockpit agents file/read Linear issues
# (no interactive OAuth). Linear → Settings → Security & access → Personal API
# keys. Leave empty to keep Linear off. Project-specific overrides are supported:
# for ~/atlas, set ATLAS_LINEAR_API_KEY or LINEAR_API_KEY_ATLAS; ShellTeam
# also reads LINEAR_API_KEY from the active project's .env or code/.env.
LINEAR_API_KEY=

# Dreaming (the `dreaming` module): nightly knowledge consolidation. The sweep's
# extraction runs headless `claude -p` on YOUR Claude subscription (the CLI's
# own login; ANTHROPIC_API_KEY is stripped so it can never silently bill an API
# key). Because it's your subscription, the default is Opus — the sweep is the
# one place worth the best model, and it runs once nightly. DREAM_MODEL is any
# alias/id the claude CLI accepts (opus | sonnet | haiku | a pinned id).
# Schedule: shellteam-dream.timer, 03:30 local.
DREAM_MODEL=opus
DREAM_EXTRACT_TIMEOUT=600

# In-product feedback ("Report a bug" in the dashboard). Reports are forwarded to
# the public ShellTeam maintainer relay — the box holds no secret. Override the
# URL to point at your own relay/webhook, or set it empty to disable the feature.
FEEDBACK_RELAY_URL=https://feedback.shellteam.sh/report
# Proof-of-work difficulty (leading zero bits) the box mints to pass the relay's
# spam gate. Keep in lockstep with the relay; 18 ≈ a fraction of a second.
FEEDBACK_POW_BITS=18

# A small "Made with ShellTeam" footer appended to HTML that THIRD PARTIES see —
# published reports and signed share links. Your own authenticated views and
# anything under ~/public are never badged. Set false to disable.
SHARE_FOOTER=true

# ── Owner notifications (optional) ────────────────────────────────────────────
# The channel the box uses to reach YOU off-box (POST /internal/notify) — for
# escalations, ship summaries, and the future dreaming brief. Auto-detected in
# priority order: Telegram first, then ntfy, else log-only (a loud WARNING so a
# missing channel is never silent). Set at most one.
#
# Telegram (rich; ~5-min setup): message @BotFather to create a bot and get its
# token, then get your numeric chat id (e.g. message @userinfobot).
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=
# ntfy.sh (zero-setup fallback): pick a hard-to-guess topic, install the ntfy app,
# and subscribe to it. Self-host by overriding NOTIFY_NTFY_SERVER.
NOTIFY_NTFY_TOPIC=
NOTIFY_NTFY_SERVER=https://ntfy.sh
