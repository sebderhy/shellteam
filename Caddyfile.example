# ShellTeam — Caddy reverse proxy (self-hosted).
# ShellTeam-managed Caddyfile — regenerated by install.sh (safe to overwrite).
#
# Caddy terminates TLS and forwards everything to the control plane on :8000,
# which serves the dashboard, the cockpit, and the subdomain proxy. Copy to
# /etc/caddy/Caddyfile (or run `caddy run --config ./Caddyfile`) and replace
# example.com with your domain.
#
# The :8000 below must match API_PORT in .env. If you changed API_PORT, update
# both reverse_proxy targets here to 127.0.0.1:<API_PORT>.
#
# For laptop / localhost use you don't need Caddy at all — just open
# http://127.0.0.1:8000 directly.

{
	# Caddy asks the control plane which subdomains may get an on-demand cert.
	on_demand_tls {
		ask http://127.0.0.1:8000/internal/check-domain
	}
}

# Main dashboard + cockpit.
example.com {
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
	reverse_proxy 127.0.0.1:8000 {
		transport http {
			versions 1.1 2
		}
		flush_interval -1
	}
}

# Owner subdomains: <name>.example.com and <name>-<port>.example.com — served by
# the control plane's subdomain proxy (file server + port forwarding).
*.example.com {
	tls {
		on_demand
	}
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
	reverse_proxy 127.0.0.1:8000 {
		transport http {
			versions 1.1 2
		}
		flush_interval -1
	}
}
